{
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "Bash(venv/bin/python -m app.cli chapter*)",
      "Bash(venv/bin/python scripts/quality_loop.py*)",
      "Bash(venv/bin/python scripts/fetch_chapter.py*)",
      "Bash(venv/bin/python scripts/evaluate_translation.py*)",
      "Bash(curl -s*52shuku.net*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-cwd.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-secret-safety.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-handoff.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
