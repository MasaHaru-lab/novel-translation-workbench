# Novel Translation Workbench — environment configuration
#
# Copy this file to .env.local and fill in your secrets.
# .env.local is gitignored — it will never be committed.
#
#   cp .env.example .env.local
#
# ── Secrets policy ──────────────────────────────────────────────────────────────
# DEEPSEEK_API_KEY is the only credential in this project.
# - Never commit .env or .env.local (both gitignored).
# - Never log, print, or display the key value.
# - The code references secrets by env var name only — never stores or logs values.
#
# ── How to set these ────────────────────────────────────────────────────────────
# Option A (recommended): set in .env.local (autoloaded by CLI/service, gitignored):
#   cp .env.example .env.local   then edit .env.local with your values
#
# Option B (takes precedence): export in your shell session:
#   export MODEL_BACKEND_URL=http://localhost:11434/api/generate
#   export DEEPSEEK_API_KEY=sk-...
#
# Option C: inline for a single command:
#   MODEL_BACKEND_URL=http://localhost:11434/api/generate venv/bin/python -m app.cli run
#
# ── How env vars are loaded ──────────────────────────────────────────────────────
# app/config_loader.py reads .env.local -> os.environ (one-time, idempotent).
# app/config.py reads MODEL_BACKEND_URL and MODEL_TIMEOUT_SECONDS at import time.
# app/translate/model_profiles.py reads DEEPSEEK_BASE_URL and DEEPSEEK_API_KEY
#   lazily at resolution time via api_base_env / api_key_env profile fields.
#
# ── MODEL_BACKEND_URL vs model profiles ─────────────────────────────────────────
# MODEL_BACKEND_URL is the legacy single-URL mode used when no --model-profile
# is passed on the CLI. Model profiles define their own base URL by env var name
# (e.g. DEEPSEEK_BASE_URL for deepseek profiles, MODEL_BACKEND_URL for local-qwen).
# When a profile is selected, its env var takes precedence. Profiles are
# registered in app/translate/model_profiles.py.

# =============================================================================
# Model backend — legacy single-URL mode (used when no --model-profile is set)
# File:   app/config.py, app/translate/backend_adapter.py
# Type:   optional; fallback when no profile is selected
# =============================================================================
# MODEL_BACKEND_URL=http://localhost:11434/api/generate

# =============================================================================
# Model timeout — applied to all backend HTTP requests
# File:   app/config.py, app/translate/backend_adapter.py
# Type:   optional; default 30
# =============================================================================
# MODEL_TIMEOUT_SECONDS=30

# =============================================================================
# DeepSeek — primary validation backend (API key required)
# File:   app/translate/model_profiles.py (profiles: deepseek-v4-flash, deepseek-v4-pro)
# Type:   DEEPSEEK_BASE_URL is fixed; DEEPSEEK_API_KEY is a SECRET
# =============================================================================
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here   # SECRET — fill in your .env.local

# =============================================================================
# Local model — prompt-HTTP mode (Fishhead / Ollama backup)
# File:   app/translate/model_profiles.py (profile: local-qwen)
# Type:   optional; for local-only or Fishhead-based translation
#
# IMPORTANT: Do not hard-code a Fishhead IP address here. Resolve the active
# host with:
#   ssh -G Fishhead-Core | grep -E '^hostname '
# The Fishhead address is managed via SSH config, not hard-coded in env files.
# =============================================================================
# FISHHEAD_BASE_URL=http://<fishhead-host>:8001/generate

# =============================================================================
# Translation service — optional HTTP service mode
# File:   app/config.py
# Type:   optional; default http://localhost:8000
# =============================================================================
# TRANSLATION_SERVICE_URL=http://localhost:8000
