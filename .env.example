# Novel Translation Workbench — environment configuration
#
# Copy this file to .env.local and fill in your secrets.
# .env.local is gitignored — it will never be committed.
#
#   cp .env.example .env.local
#
# =============================================================================
# Model backend — legacy single-URL mode (used when no --model-profile is set)
# =============================================================================
# MODEL_BACKEND_URL=http://localhost:11434/api/generate

# =============================================================================
# DeepSeek (primary validation backend)
# =============================================================================
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# =============================================================================
# Local model — prompt-HTTP mode (manual backup, Fishhead / Ollama)
# =============================================================================
# FISHHEAD_BASE_URL=http://<fishhead-host>:8001/generate

# =============================================================================
# Translation service (optional HTTP service mode)
# =============================================================================
# TRANSLATION_SERVICE_URL=http://localhost:8000
